#!/usr/bin/env bash
# Pre-commit hook: run ruff format on staged Python files

STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')

if [ -z "$STAGED_PY_FILES" ]; then
    exit 0
fi

# Format only the staged Python files
uv run ruff format $STAGED_PY_FILES

# Re-stage the formatted files
git add $STAGED_PY_FILES
